{
  "name": "react-on-fly",
  "version": "1.0.0",
  "description": "Compile and serve a react file on the fly",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0",
    "deno": ">=1.38.0"
  },
  "homepage": "https://github.com/zMattew/react-fly#readme",
  "bugs": {
    "url": "https://github.com/zMattew/react-fly/issues"
  },
  "main": "dist/main.js",
  "author": "zMattew_",
  "license": "MIT",
  "repository": "zMattew/react-fly",
  "keywords": [
    "react",
    "previewer",
    "lightweight",
    "compiler",
    "serve",
    "cli",
    "esbuild",
    "zero-config",
    "single-file",
    "runner",
    "prototyping",
    "tailwind",
    "dev-server"
  ],
  "bin": {
    "react-on-fly": "./dist/main.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "tsc --noEmit"
  },
  "dependencies": {
    "esbuild": "^0.27.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.1-rc"
  }
}
